# ============================================
# Variables de Entorno - Portafolio Julio Cesar
# ============================================
# Copia este archivo a .env y completa los valores

# ============================================
# Formspree - Para el formulario de contacto
# ============================================
# 1. Ve a https://formspree.io
# 2. Crea una cuenta gratis
# 3. Crea un nuevo formulario
# 4. Reemplaza el valor abajo con tu endpoint
VITE_FORMSPREE_URL=https://formspree.io/f/TU_ID_AQUI

# ============================================
# Google Analytics (Opcional)
# ============================================
# Si quieres agregar analytics, descomenta y pon tu ID
# VITE_GA_ID=G-XXXXXXXXXX

# ============================================
# URLs de Redes Sociales (Opcional - para override)
# ============================================
